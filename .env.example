# adlo.tw environment variables — 範本
#
# 規則（依 CLAUDE.md §4）:
# - 此檔以假值為主，確保不洩漏 production 機密
# - 真實值放 .env.local（已在 .gitignore），或 Vercel Environment Variables
# - 命名建議加後綴標示權限：_RO（read-only）/ _RW（write）/ _LIVE（production）
# - production 寫入 token (_RW / _LIVE) 永不放 agent shell（CLAUDE.md §4.2）
#
# 設定步驟：
#   1. cp .env.example .env.local
#   2. 將下列 __PASTE_*__ 替換為真實值
#   3. 重啟 dev server (npm run dev)

# ── 必要：基礎服務 ─────────────────────────────────────
# Upstash Redis (rate-limit, cost-cap)
UPSTASH_REDIS_REST_URL=https://example-12345.upstash.io
UPSTASH_REDIS_REST_TOKEN=__PASTE_UPSTASH_TOKEN__

# Google Places API (New) — /check, /tools/competitor 用
# 申請：GCP Console → APIs & Services → Places API (New)
GOOGLE_PLACES_API_KEY=__PASTE_GOOGLE_PLACES_API_KEY__

# Groq Llama free tier — /tools/post-writer 用
# 申請：https://console.groq.com → API Keys
GROQ_API_KEY=__PASTE_GROQ_API_KEY__

# Resend — transactional email
RESEND_API_KEY=__PASTE_RESEND_API_KEY__

# /admin 區管理員密碼（請用強隨機字串）
ADMIN_SECRET=__PASTE_ADMIN_SECRET__

# ── 公開：分析追蹤（NEXT_PUBLIC_ 前綴會打包進 client）─
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ── Stripe ──────────────────────────────────────────
# Stripe API（使用 test 模式：sk_test_...）
# 規則：agent shell 只配 _TEST，_LIVE 只在 Vercel Production
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXX

# Stripe Price IDs（產品定價，dashboard → Products）
STRIPE_PRICE_STARTER_MONTHLY=price_XXXXX
STRIPE_PRICE_STARTER_YEARLY=price_XXXXX
STRIPE_PRICE_GROWTH_MONTHLY=price_XXXXX
STRIPE_PRICE_GROWTH_YEARLY=price_XXXXX
STRIPE_PRICE_DOMINATE_MONTHLY=price_XXXXX
STRIPE_PRICE_DOMINATE_YEARLY=price_XXXXX
